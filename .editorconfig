root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
charset = utf-8-bom
trim_trailing_whitespace = false

[*.cs]
charset = utf-8-bom

[*.csproj]
charset = utf-8-bom

[*.ps1]
charset = utf-8-bom

[*.bat]
charset = utf-8

[*.{ts,js,json,toml,sql,yml,yaml}]
charset = utf-8

